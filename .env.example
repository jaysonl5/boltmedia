# Copy to .env and fill in. .env is gitignored.

# Docker Hub (image registry) — account: boltokc
KAMAL_REGISTRY_USER=boltokc
KAMAL_REGISTRY_PASSWORD=your-dockerhub-access-token

# Hetzner server (shared with the other Kamal sites)
HETZNER_IP=178.104.95.80
HETZNER_SSH_KEY=~/.ssh/hetzner_key

# Contact form SMTP (Gmail relay)
SMTP_HOST=smtp-relay.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-app-password
# Quote any value with spaces or < > — .env is sourced by the shell.
SMTP_FROM="Bolt Media OKC <noreply@boltmediaokc.com>"
CONTACT_EMAIL=contact@boltmediaokc.com
